generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String   @id @default(cuid())
  email             String?  @unique
  phone             String   @unique
  name              String?
  role              String   @default("member")
  uplineId          String?
  upline            User?            @relation("DownlineTree", fields: [uplineId], references: [id])
  downlines         User[]           @relation("DownlineTree")
  referralCode      String           @unique
  commissionBalance Float            @default(0)
  createdAt         DateTime         @default(now())

  orders            Order[]
  wholesaleApp      WholesaleApplication?
  commissionAsUpline  CommissionTransaction[] @relation("UplineTxns")
  commissionAsDownline CommissionTransaction[] @relation("DownlineTxns")
  withdrawals       WithdrawalRequest[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  brand            String
  origin           String
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id])
  description      String
  details          String   @default("[]")
  images           String   @default("[]")
  retailPrice      Float
  wholesalePriceL1 Float
  wholesalePriceL2 Float
  costPrice        Float
  stock            Int      @default(0)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  badge            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orderItems       OrderItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  products Product[]
}

model Order {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  orderType        String      @default("retail")
  totalAmount      Float
  status           String      @default("pending")
  shippingAddress  String
  shippingMethod   String
  paymentMethod    String?
  paymentStatus    String      @default("unpaid")
  uplineId         String?
  commissionAmount Float?
  commissionStatus String?
  createdAt        DateTime    @default(now())

  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}

model WholesaleApplication {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  companyName    String
  contactName    String
  phone          String
  email          String
  businessRegUrl String?
  website        String?
  notes          String?
  referralCode   String?
  status         String    @default("pending")
  approvedLevel  String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
}

model CommissionTransaction {
  id              String    @id @default(cuid())
  orderId         String
  uplineId        String
  upline          User      @relation("UplineTxns", fields: [uplineId], references: [id])
  downlineId      String
  downline        User      @relation("DownlineTxns", fields: [downlineId], references: [id])
  profitAmount    Float
  commissionRate  Float
  amount          Float
  status          String    @default("pending")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
}

model WithdrawalRequest {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  amount          Float
  bankName        String
  bankAccountName String
  bankAccountNo   String
  status          String    @default("pending")
  adminNote       String?
  processedAt     DateTime?
  processedBy     String?
  createdAt       DateTime  @default(now())
}
