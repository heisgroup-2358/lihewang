generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
}

model Origin {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
}

model VerificationCode {
  id        String   @id @default(cuid())
  target    String   @unique // email or phone
  code      String
  channel   String   // "email" or "whatsapp"
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id                   String                    @id @default(cuid())
  email                String?                   @unique
  phone                String                    @unique
  name                 String?
  role                 String                    @default("member")
  uplineId             String?
  referralCode         String                    @unique
  commissionBalance    Float                     @default(0)
  createdAt            DateTime                  @default(now())
  upline               User?                     @relation("UserReferral", fields: [uplineId], references: [id])
  downlines            User[]                    @relation("UserReferral")
  orders               Order[]
  wholesaleApplications WholesaleApplication[]
  commissionTransactionsAsUpline   CommissionTransaction[] @relation("CommissionUpline")
  commissionTransactionsAsDownline CommissionTransaction[] @relation("CommissionDownline")
  withdrawalRequests   WithdrawalRequest[]
}

model Product {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  brand             String
  origin            String
  categoryId        String
  description       String
  details           String         @default("[]")
  images            String         @default("[]")
  retailPrice       Float
  wholesalePriceL1  Float
  wholesalePriceL2  Float
  costPrice         Float
  stock             Int            @default(0)
  rating            Float          @default(0)
  reviewCount       Int            @default(0)
  badge             String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  category          Category       @relation(fields: [categoryId], references: [id])
  orderItems        OrderItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  products Product[]
}

model Order {
  id                String                     @id @default(cuid())
  userId            String
  orderType         String                     @default("retail")
  totalAmount       Float
  status            String                     @default("pending")
  shippingAddress   String
  shippingMethod    String
  paymentMethod     String?
  paymentStatus     String                     @default("unpaid")
  uplineId          String?
  commissionAmount  Float?
  commissionStatus  String?
  createdAt         DateTime                   @default(now())
  user              User                       @relation(fields: [userId], references: [id])
  items             OrderItem[]
  commissionTransactions CommissionTransaction[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model WholesaleApplication {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String
  contactName   String
  phone         String
  email         String
  businessRegUrl String?
  website       String?
  notes         String?
  referralCode  String?
  status        String   @default("pending")
  approvedLevel String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model CommissionTransaction {
  id              String    @id @default(cuid())
  orderId         String
  uplineId        String
  downlineId      String
  profitAmount    Float
  commissionRate  Float
  amount          Float
  status          String    @default("pending")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  order           Order     @relation(fields: [orderId], references: [id])
  upline          User      @relation("CommissionUpline", fields: [uplineId], references: [id])
  downline        User      @relation("CommissionDownline", fields: [downlineId], references: [id])
}

model WithdrawalRequest {
  id              String    @id @default(cuid())
  userId          String
  amount          Float
  bankName        String
  bankAccountName String
  bankAccountNo   String
  status          String    @default("pending")
  adminNote       String?
  processedAt     DateTime?
  processedBy     String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id])
}
