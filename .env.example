# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/lihewang"

# Site URL (used for links and redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Twilio Verify (phone OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# JWT secret for session cookies (generate a random 64-char string)
JWT_SECRET=

# Resend (email OTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@lihewang.com

# Cloudflare Turnstile (CAPTCHA on login/register)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# PaymentAsia
PAYMENT_MERCHANT_TOKEN=
PAYMENT_SECRET_CODE=
PAYMENT_X_API_KEY=
PAYMENT_GATEWAY_URL=https://gateway-sandbox.pa-sys.com

# Supabase (file uploads)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
